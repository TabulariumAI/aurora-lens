{
  "name": "@tabularium/aurora-lens",
  "version": "0.1.0",
  "description": "Framework-agnostic document viewer with metadata overlays, selection, search, thumbnails, and pluggable raster decoding.",
  "type": "module",
  "license": "Apache-2.0",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./react": {
      "types": "./dist/react/index.d.ts",
      "import": "./dist/react/index.js"
    }
  },
  "files": [
    "dist",
    "docs",
    "NOTICE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepack": "npm run build",
    "test": "vitest run"
  },
  "keywords": [
    "document-viewer",
    "metadata",
    "overlay",
    "selection",
    "react",
    "viewer",
    "aurora-lens"
  ],
  "author": "Tabularium AI",
  "repository": {
    "type": "git",
    "url": "https://github.com/tabulariumai/aurora-lens.git",
    "directory": "packages/aurora-lens"
  },
  "bugs": {
    "url": "https://github.com/tabulariumai/aurora-lens/issues"
  },
  "homepage": "https://github.com/tabulariumai/aurora-lens/tree/main/packages/aurora-lens#readme",
  "sideEffects": false,
  "dependencies": {
    "fuse.js": "6.6.2"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "jsdom": "^29.1.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "typescript": "^6.0.3",
    "vite": "^8.0.11",
    "vitest": "^4.1.5"
  }
}
